# 合约信息 API 地址（必填）
INS_API_URL=http://your-external-api/ins

# 价格 API 地址（必填）
PRICE_API_URL=http://your-external-api/price

# Redis 连接地址
REDIS_URL=redis://localhost:6379/0

# 缓存 TTL（秒），默认 5 分钟
CACHE_TTL_SECONDS=300

# 定时刷新间隔（秒），默认 1 分钟
REFRESH_INTERVAL_SECONDS=60

# 单次查询最大返回条数
MAX_LIMIT=500

# 默认返回条数
DEFAULT_LIMIT=50

# /ins 中 pi.pt 字段值 → 期权（逗号分隔），1=期货, 2=期权, 6=个股期权
OPTION_TYPES=2

# /ins 中 pi.pt 字段值 → 期货（逗号分隔）
FUTURE_TYPES=1

# 日志级别
LOG_LEVEL=INFO

# K 线历史数据 TCP 服务地址
KLINE_TCP_HOST=

# K 线历史数据 TCP 服务端口
KLINE_TCP_PORT=

# TCP 连接/读取超时（秒）
KLINE_TCP_TIMEOUT=10

# TCP 网络瞬时故障自动重试次数（不含首次，指数退避）
KLINE_TCP_MAX_RETRIES=3
