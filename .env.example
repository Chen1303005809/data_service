# 合约信息 API 地址（必填）
INS_API_URL=http://your-external-api/ins

# 价格 API 地址（必填）
PRICE_API_URL=http://your-external-api/price

# Redis 连接地址
REDIS_URL=redis://localhost:6379/0

# 缓存 TTL（秒），默认 5 分钟
CACHE_TTL_SECONDS=300

# 合约（期货/期权）刷新间隔（秒），默认 10 秒
CONTRACTS_REFRESH_INTERVAL_SECONDS=10

# 现货刷新间隔（秒），默认 4 小时
SPOT_REFRESH_INTERVAL_SECONDS=14400

# 单次查询最大返回条数
MAX_LIMIT=500

# 默认返回条数
DEFAULT_LIMIT=50

# /ins 中 pi.pt 字段值 → 期权（逗号分隔），1=期货, 2=期权, 6=个股期权
OPTION_TYPES=2

# /ins 中 pi.pt 字段值 → 期货（逗号分隔）
FUTURE_TYPES=1

# 现货数据（akshare）: 默认启用，设为 false 关闭
SPOT_ENABLED=true

# 日志级别
LOG_LEVEL=INFO
